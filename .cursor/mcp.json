{
  "mcpServers": {
    "agent-zero": {
      "type": "sse",
      "url": "${AGENT_ZERO_BASE_URL}/${AGENT_ZERO_TOKEN}/sse"
    },
    "agent-zero-http": {
      "type": "http",
      "url": "${AGENT_ZERO_BASE_URL}/${AGENT_ZERO_TOKEN}/http"
    },
    "apify": {
      "type": "http",
      "url": "https://mcp.apify.com?token=${APIFY_API_TOKEN}"
    },
    "browsermcp": {
      "command": "npx",
      "args": ["@browsermcp/mcp@latest"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"]
    },
    "motion": {
      "command": "npx",
      "args": ["-y", "https://api.motion.dev/registry.tgz?package=motion-studio-mcp&version=latest"]
    },
    "pencil": {
      "name": "pencil",
      "transport": "stdio",
      "command": "${PENCIL_MCP_PATH}",
      "args": ["--app", "cursor"],
      "env": {}
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "Ref": {
      "type": "http",
      "url": "https://api.ref.tools/mcp?apiKey=${REF_API_KEY}"
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase",
        "--read-only",
        "--project-ref=<project-ref>"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "<access-token>"
      }
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    }
  }
}
