# Claude Code MCP Aliases
# Automatically load .env variables when running Claude with MCP configs

alias claude-mcp='set -a && source ~/mcp/.env && set +a && claude'
alias claude-all='set -a && source ~/mcp/.env && set +a && claude \
  --mcp-config ~/mcp/server/agent-zero.json \
  --mcp-config ~/mcp/server/apify.json \
  --mcp-config ~/mcp/server/browsermcp.json \
  --mcp-config ~/mcp/server/chrome-devtools.json \
  --mcp-config ~/mcp/server/context7.json \
  --mcp-config ~/mcp/server/github.json \
  --mcp-config ~/mcp/server/motion.json \
  --mcp-config ~/mcp/server/pencildev.json \
  --mcp-config ~/mcp/server/playwright.json \
  --mcp-config ~/mcp/server/ref.json \
  --mcp-config ~/mcp/server/sequential-thinking.json \
  --mcp-config ~/mcp/server/supabase.json \
  --mcp-config ~/mcp/server/vercel.json'
alias claude-ref='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/ref.json'
alias claude-context7='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/context7.json'
alias claude-playwright='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/playwright.json'
alias claude-sthink='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/sequential-thinking.json'
alias claude-github='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/github.json'
alias claude-motion='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/motion.json'
alias claude-supabase='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/supabase.json'
alias claude-browsermcp='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/browsermcp.json'
alias claude-devtools='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/chrome-devtools.json'
alias claude-vercel='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/vercel.json'
alias claude-a0='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/agent-zero.json'
alias claude-apify='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/apify.json'
alias claude-pencil='set -a && source ~/mcp/.env && set +a && claude --mcp-config ~/mcp/server/pencildev.json'

alias cld='claude --dangerously-skip-permissions'
alias cursor='agent --yolo'
# Cursor: tek MCP ile aç (.cursor/mcp.json içindeki identifier ile eşleşir)
alias cursor-agent-zero='set -a && source ~/mcp/.env && set +a && cursor mcp enable agent-zero && cursor'
alias cursor-agent-zero-http='set -a && source ~/mcp/.env && set +a && cursor mcp enable agent-zero-http && cursor'
alias cursor-apify='set -a && source ~/mcp/.env && set +a && cursor mcp enable apify && cursor'
alias cursor-browsermcp='set -a && source ~/mcp/.env && set +a && cursor mcp enable browsermcp && cursor'
alias cursor-context7='set -a && source ~/mcp/.env && set +a && cursor mcp enable context7 && cursor'
alias cursor-devtools='set -a && source ~/mcp/.env && set +a && cursor mcp enable chrome-devtools && cursor'
alias cursor-github='set -a && source ~/mcp/.env && set +a && cursor mcp enable github && cursor'
alias cursor-motion='set -a && source ~/mcp/.env && set +a && cursor mcp enable motion && cursor'
alias cursor-pencil='set -a && source ~/mcp/.env && set +a && cursor mcp enable pencil && cursor'
alias cursor-playwright='set -a && source ~/mcp/.env && set +a && cursor mcp enable playwright && cursor'
alias cursor-ref='set -a && source ~/mcp/.env && set +a && cursor mcp enable Ref && cursor'
alias cursor-sequential-thinking='set -a && source ~/mcp/.env && set +a && cursor mcp enable sequential-thinking && cursor'
alias cursor-sthink='set -a && source ~/mcp/.env && set +a && cursor mcp enable sequential-thinking && cursor'
alias cursor-supabase='set -a && source ~/mcp/.env && set +a && cursor mcp enable supabase && cursor'
alias cursor-vercel='set -a && source ~/mcp/.env && set +a && cursor mcp enable vercel && cursor'
alias cursor-disable-agent-zero='cursor mcp disable agent-zero'
alias cursor-disable-agent-zero-http='cursor mcp disable agent-zero-http'
alias cursor-disable-apify='cursor mcp disable apify'
alias cursor-disable-browsermcp='cursor mcp disable browsermcp'
alias cursor-disable-context7='cursor mcp disable context7'
alias cursor-disable-devtools='cursor mcp disable chrome-devtools'
alias cursor-disable-github='cursor mcp disable github'
alias cursor-disable-motion='cursor mcp disable motion'
alias cursor-disable-pencil='cursor mcp disable pencil'
alias cursor-disable-playwright='cursor mcp disable playwright'
alias cursor-disable-ref='cursor mcp disable Ref'
alias cursor-disable-sequential-thinking='cursor mcp disable sequential-thinking'
alias cursor-disable-sthink='cursor mcp disable sequential-thinking'
alias cursor-disable-supabase='cursor mcp disable supabase'
alias cursor-disable-vercel='cursor mcp disable vercel'
alias cursor-disable-all='cursor mcp disable agent-zero && cursor mcp disable agent-zero-http && cursor mcp disable apify && cursor mcp disable browsermcp && cursor mcp disable chrome-devtools && cursor mcp disable context7 && cursor mcp disable github && cursor mcp disable motion && cursor mcp disable pencil && cursor mcp disable playwright && cursor mcp disable Ref && cursor mcp disable sequential-thinking && cursor mcp disable supabase && cursor mcp disable vercel'